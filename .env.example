# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║              Ba-Yu — Production Environment (Render)                       ║
# ║                                                                            ║
# ║  Salin semua variabel ini ke Render Dashboard → Environment.               ║
# ║  JANGAN commit file .env yang sudah terisi ke GitHub!                      ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# ┌──────────────────────────────────────────────────────────────────────────────┐
# │ 1. APPLICATION CORE                                                        │
# │                                                                            │
# │ APP_URL: Isi dengan URL Render kamu setelah deploy pertama.                │
# │ Contoh: https://bayu-xxxx.onrender.com                                    │
# └──────────────────────────────────────────────────────────────────────────────┘
APP_NAME="Ba-Yu"
APP_ENV=production
APP_DEBUG=false
APP_KEY=
APP_URL=https://bayu-xxxx.onrender.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file

# ┌──────────────────────────────────────────────────────────────────────────────┐
# │ 2. SECURITY                                                                │
# └──────────────────────────────────────────────────────────────────────────────┘
BCRYPT_ROUNDS=12

# ┌──────────────────────────────────────────────────────────────────────────────┐
# │ 3. LOGGING                                                                 │
# │                                                                            │
# │ Di production, gunakan "warning" atau "error" agar log tidak membengkak.   │
# │ Render menampilkan log di Dashboard → Logs.                                │
# └──────────────────────────────────────────────────────────────────────────────┘
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# ┌──────────────────────────────────────────────────────────────────────────────┐
# │ 4. DATABASE — MongoDB Atlas                                                │
# │                                                                            │
# │ Dapatkan URI dari: https://cloud.mongodb.com → Database → Connect         │
# │                                                                            │
# │ ⚠️ PENTING: Di MongoDB Atlas → Network Access, tambahkan 0.0.0.0/0        │
# │    (Allow from Anywhere) karena IP Render berubah-ubah!                    │
# └──────────────────────────────────────────────────────────────────────────────┘
DB_CONNECTION=mongodb
MONGODB_URI="mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority"
MONGODB_DATABASE="bayu"

# ┌──────────────────────────────────────────────────────────────────────────────┐
# │ 5. SESSION & AUTH                                                          │
# │                                                                            │
# │ ⚠️ WAJIB "cookie" atau "file" — JANGAN "database" (tidak ada tabel SQL)!  │
# │ SESSION_SECURE_COOKIE=true karena Render selalu HTTPS.                     │
# └──────────────────────────────────────────────────────────────────────────────┘
SESSION_DRIVER=cookie
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true

# Sanctum API token expiration: 30 hari = 43200 menit
SANCTUM_TOKEN_EXPIRATION=43200

# ┌──────────────────────────────────────────────────────────────────────────────┐
# │ 6. QUEUE, CACHE, BROADCAST                                                │
# │                                                                            │
# │ ⚠️ WAJIB "sync" untuk queue dan "file" untuk cache.                       │
# │ JANGAN "database" — MongoDB tidak punya tabel jobs/cache!                  │
# └──────────────────────────────────────────────────────────────────────────────┘
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
CACHE_STORE=file

# ┌──────────────────────────────────────────────────────────────────────────────┐
# │ 7. MAIL — Gmail SMTP                                                      │
# │                                                                            │
# │ Untuk verifikasi email & reset password.                                   │
# │ Gunakan Gmail App Password (bukan password akun biasa):                    │
# │ https://myaccount.google.com/apppasswords                                  │
# │                                                                            │
# │ ⚠️ MAIL_ENCRYPTION harus "tls" (BUKAN "tsl" — itu typo!)                 │
# └──────────────────────────────────────────────────────────────────────────────┘
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME="support.bayu@gmail.com"
MAIL_PASSWORD="your-gmail-app-password"
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="support.bayu@gmail.com"
MAIL_FROM_NAME="Ba-Yu Support"

# ┌──────────────────────────────────────────────────────────────────────────────┐
# │ 8. CLOUDINARY — Image/File Storage                                         │
# │                                                                            │
# │ Digunakan untuk: avatar, sertifikat pakar, thumbnail catatan.              │
# │ Dapatkan URL dari: https://cloudinary.com/console                          │
# │ Format: cloudinary://API_KEY:API_SECRET@CLOUD_NAME                         │
# └──────────────────────────────────────────────────────────────────────────────┘
CLOUDINARY_URL="cloudinary://API_KEY:API_SECRET@CLOUD_NAME"

# ┌──────────────────────────────────────────────────────────────────────────────┐
# │ 9. FIREBASE — Push Notifications (FCM)                                     │
# │                                                                            │
# │ Karena Render tidak support upload file, PASTE seluruh isi file            │
# │ firebase-credentials.json sebagai VALUE dari variabel ini.                 │
# │                                                                            │
# │ Contoh (satu baris, tanpa line break):                                     │
# │ {"type":"service_account","project_id":"ba-yu-mobile",...}                 │
# └──────────────────────────────────────────────────────────────────────────────┘
FIREBASE_CREDENTIALS=

# ┌──────────────────────────────────────────────────────────────────────────────┐
# │ 10. GOOGLE OAuth                                                           │
# │                                                                            │
# │ Manage di: https://console.cloud.google.com/apis/credentials               │
# │                                                                            │
# │ ⚠️ SETELAH DEPLOY: Tambahkan URL Render kamu ke Google Console:            │
# │    - Authorized redirect URIs: https://bayu-xxxx.onrender.com/api/auth/google/callback
# │    - Authorized JavaScript origins: https://bayu-xxxx.onrender.com         │
# │                                                                            │
# │ GOOGLE_ALLOWED_AUDIENCES: isi dengan Web Client ID + Mobile Client ID,     │
# │ dipisahkan koma (tanpa spasi).                                             │
# └──────────────────────────────────────────────────────────────────────────────┘
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://bayu-xxxx.onrender.com/api/auth/google/callback
GOOGLE_ALLOWED_AUDIENCES=

# ┌──────────────────────────────────────────────────────────────────────────────┐
# │ 11. FACEBOOK OAuth                                                         │
# │                                                                            │
# │ Manage di: https://developers.facebook.com/apps                            │
# └──────────────────────────────────────────────────────────────────────────────┘
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI=https://bayu-xxxx.onrender.com/api/auth/facebook/callback

# ┌──────────────────────────────────────────────────────────────────────────────┐
# │ 12. VITE (Frontend)                                                        │
# └──────────────────────────────────────────────────────────────────────────────┘
VITE_APP_NAME="${APP_NAME}"

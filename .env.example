# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║                        Ba-Yu — Environment Configuration                   ║
# ║                                                                            ║
# ║  Copy this file to `.env` and fill in the values.                          ║
# ║  NEVER commit the actual `.env` file to version control!                   ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# ┌──────────────────────────────────────────────────────────────────────────────┐
# │ 1. APPLICATION CORE                                                        │
# └──────────────────────────────────────────────────────────────────────────────┘
APP_NAME="Ba-Yu"

# For LOCAL development:
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000

# For PRODUCTION (uncomment these and remove the local ones above):
# APP_ENV=production
# APP_DEBUG=false
# APP_URL=https://your-domain.com

# Generate with: php artisan key:generate
APP_KEY=

# Required in production if APP_URL alone isn't enough for Vite asset links.
# Set to the same value as APP_URL.
# ASSET_URL=https://your-domain.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

# ┌──────────────────────────────────────────────────────────────────────────────┐
# │ 2. SECURITY                                                                │
# └──────────────────────────────────────────────────────────────────────────────┘
# Higher = more secure but slower hashing. 12 is a good production default.
BCRYPT_ROUNDS=12

# ┌──────────────────────────────────────────────────────────────────────────────┐
# │ 3. LOGGING                                                                 │
# └──────────────────────────────────────────────────────────────────────────────┘
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null

# For LOCAL: "debug" to see everything.
# For PRODUCTION: "warning" or "error" to reduce noise.
LOG_LEVEL=debug

# ┌──────────────────────────────────────────────────────────────────────────────┐
# │ 4. DATABASE — MongoDB Atlas                                                │
# │                                                                            │
# │ Ba-Yu uses MongoDB exclusively. Get your connection string from:           │
# │ https://cloud.mongodb.com → Database → Connect → Drivers                  │
# └──────────────────────────────────────────────────────────────────────────────┘
DB_CONNECTION=mongodb
MONGODB_URI="mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority"
MONGODB_DATABASE="bayu"

# ┌──────────────────────────────────────────────────────────────────────────────┐
# │ 5. SESSION & AUTH                                                          │
# │                                                                            │
# │ ⚠️  DO NOT use "database" driver — MongoDB has no sessions table.          │
# │ Use "file" for local, "cookie" for production (stateless, no disk needed). │
# └──────────────────────────────────────────────────────────────────────────────┘

# For LOCAL:
SESSION_DRIVER=file

# For PRODUCTION (recommended, no disk/db dependency):
# SESSION_DRIVER=cookie

SESSION_LIFETIME=120

# Set to true in PRODUCTION for encrypted session cookies.
SESSION_ENCRYPT=false

SESSION_PATH=/

# For PRODUCTION: set to your domain (e.g., ".your-domain.com")
SESSION_DOMAIN=null

# For PRODUCTION: set to true (HTTPS-only cookies)
# SESSION_SECURE_COOKIE=true

# Sanctum API token expiration in minutes (default: 30 days = 43200)
SANCTUM_TOKEN_EXPIRATION=43200

# For PRODUCTION: add your domain here so Sanctum SPA auth works correctly.
# Example: "your-domain.com,www.your-domain.com"
# SANCTUM_STATEFUL_DOMAINS=

# ┌──────────────────────────────────────────────────────────────────────────────┐
# │ 6. QUEUE, CACHE, BROADCAST                                                │
# │                                                                            │
# │ ⚠️  DO NOT use "database" for queue/cache — there are no MySQL tables.     │
# │ Use "sync" for queue (processes jobs immediately, no worker needed).        │
# │ Use "file" for cache (simple and works everywhere).                        │
# └──────────────────────────────────────────────────────────────────────────────┘
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
CACHE_STORE=file

# ┌──────────────────────────────────────────────────────────────────────────────┐
# │ 7. MAIL — Gmail SMTP (for email verification & password reset)             │
# │                                                                            │
# │ Use Gmail App Password (NOT your real password):                           │
# │ https://myaccount.google.com/apppasswords                                  │
# │                                                                            │
# │ For LOCAL testing, set MAIL_MAILER=log to write emails to laravel.log      │
# └──────────────────────────────────────────────────────────────────────────────┘

# For LOCAL (emails go to storage/logs/laravel.log):
# MAIL_MAILER=log

# For PRODUCTION:
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME="support.bayu@gmail.com"
MAIL_PASSWORD="your-gmail-app-password-here"
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="support.bayu@gmail.com"
MAIL_FROM_NAME="Ba-Yu Support"

# ┌──────────────────────────────────────────────────────────────────────────────┐
# │ 8. CLOUDINARY — Image/File Storage                                         │
# │                                                                            │
# │ Used for: avatar uploads, sertifikat pakar, note thumbnails.               │
# │ Get your URL from: https://cloudinary.com/console                          │
# │ Format: cloudinary://API_KEY:API_SECRET@CLOUD_NAME                         │
# └──────────────────────────────────────────────────────────────────────────────┘
CLOUDINARY_URL="cloudinary://API_KEY:API_SECRET@CLOUD_NAME"

# ┌──────────────────────────────────────────────────────────────────────────────┐
# │ 9. FIREBASE — Push Notifications (FCM)                                     │
# │                                                                            │
# │ Used for: sending push notifications to the Ba-Yu mobile app.              │
# │ Download the service account JSON from Firebase Console:                   │
# │ Project Settings → Service accounts → Generate new private key             │
# │                                                                            │
# │ Place the downloaded JSON file in `storage/app/` and set the path below.   │
# │ For PRODUCTION: you may also set FIREBASE_CREDENTIALS as the raw JSON      │
# │ content via environment variable (Railway/Render support this).            │
# └──────────────────────────────────────────────────────────────────────────────┘
FIREBASE_CREDENTIALS=storage/app/firebase-credentials.json

# ┌──────────────────────────────────────────────────────────────────────────────┐
# │ 10. GOOGLE OAuth (Socialite for Web + ID-token verify for Mobile)          │
# │                                                                            │
# │ Create credentials at: https://console.cloud.google.com/apis/credentials   │
# │                                                                            │
# │ GOOGLE_REDIRECT_URI must match the "Authorized redirect URIs" exactly.     │
# │ For LOCAL:  http://localhost:8000/api/auth/google/callback                  │
# │ For PROD:   https://your-domain.com/api/auth/google/callback               │
# │                                                                            │
# │ GOOGLE_ALLOWED_AUDIENCES: comma-separated list of OAuth Client IDs.        │
# │ Include BOTH the web client ID and the mobile/native web client ID,        │
# │ because native Google Sign-In mints tokens with aud = mobile client ID.    │
# └──────────────────────────────────────────────────────────────────────────────┘
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback
GOOGLE_ALLOWED_AUDIENCES=

# ┌──────────────────────────────────────────────────────────────────────────────┐
# │ 11. FACEBOOK OAuth                                                         │
# │                                                                            │
# │ Create app at: https://developers.facebook.com/apps                        │
# │ FACEBOOK_REDIRECT_URI must match "Valid OAuth Redirect URIs" exactly.       │
# └──────────────────────────────────────────────────────────────────────────────┘
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI=http://localhost:8000/api/auth/facebook/callback

# ┌──────────────────────────────────────────────────────────────────────────────┐
# │ 12. VITE (Frontend Build)                                                  │
# └──────────────────────────────────────────────────────────────────────────────┘
VITE_APP_NAME="${APP_NAME}"
